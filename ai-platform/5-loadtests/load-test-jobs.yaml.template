apiVersion: v1
kind: ConfigMap
metadata:
  name: load-test-script
  namespace: default
data:
  load_test.py: |
{{LOAD_TEST_SCRIPT_CONTENT}}
---
apiVersion: batch/v1
kind: Job
metadata:
  name: load-test-east
  namespace: default
spec:
  ttlSecondsAfterFinished: 600
  template:
    spec:
      containers:
      - name: load-test
        image: python:3.9-slim
        command: ["/bin/sh", "-c"]
        args:
        - |
          pip install requests --no-cache-dir > /dev/null 2>&1 || true
          python3 /scripts/load_test.py --url http://{{GATEWAY_IP}} --model google/gemma-3-1b-it --region us-east1
        volumeMounts:
        - name: script-vol
          mountPath: /scripts
      restartPolicy: Never
      volumes:
      - name: script-vol
        configMap:
          name: load-test-script
      nodeSelector:
        topology.kubernetes.io/region: us-east1
---
apiVersion: batch/v1
kind: Job
metadata:
  name: load-test-west
  namespace: default
spec:
  ttlSecondsAfterFinished: 600
  template:
    spec:
      containers:
      - name: load-test
        image: python:3.9-slim
        command: ["/bin/sh", "-c"]
        args:
        - |
          pip install requests --no-cache-dir > /dev/null 2>&1 || true
          python3 /scripts/load_test.py --url http://{{GATEWAY_IP}} --model google/gemma-3-1b-it --region us-west1
        volumeMounts:
        - name: script-vol
          mountPath: /scripts
      restartPolicy: Never
      volumes:
      - name: script-vol
        configMap:
          name: load-test-script
      nodeSelector:
        topology.kubernetes.io/region: us-west1
